# ==================== 🗄️ DATABASE LAYER ====================
class Database:
    """Advanced database operations with connection pooling"""
    
    def __init__(self, db_name: str = 'adwatch_beast.db'):
        self.db_name = db_name
        self.init_db()
    
    def get_conn(self):
        return sqlite3.connect(self.db_name, check_same_thread=False)
    
    def init_db(self):
        """Initialize database with all tables"""
        conn = self.get_conn()
        c = conn.cursor()
        
        # Users table with full gamification
        c.execute('''
            CREATE TABLE IF NOT EXISTS users (
                user_id INTEGER PRIMARY KEY,
                username TEXT,
                first_name TEXT,
                last_name TEXT,
                points INTEGER DEFAULT 0,
                total_earned INTEGER DEFAULT 0,
                ads_watched INTEGER DEFAULT 0,
                level INTEGER DEFAULT 1,
                streak_days INTEGER DEFAULT 0,
                last_active DATE,
                last_ad_watch TIMESTAMP,
                last_daily_bonus TIMESTAMP,
                referral_code TEXT UNIQUE,
                referred_by INTEGER,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                is_banned INTEGER DEFAULT 0
            )
        ''')
        
        # Withdrawals table
        c.execute('''
            CREATE TABLE IF NOT EXISTS withdrawals (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER,
                amount INTEGER,
                method TEXT,
                address TEXT,
                status TEXT DEFAULT 'pending',
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                processed_at TIMESTAMP,
                FOREIGN KEY (user_id) REFERENCES users(user_id)
            )
        ''')
        
        # Ad watch history
        c.execute('''
            CREATE TABLE IF NOT EXISTS ad_history (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER,
                points_earned INTEGER,
                watched_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (user_id) REFERENCES users(user_id)
            )
        ''')
        
        # Referrals tracking
        c.execute('''
            CREATE TABLE IF NOT EXISTS referrals (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                referrer_id INTEGER,
                referred_id INTEGER,
                earned_points INTEGER DEFAULT 0,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (referrer_id) REFERENCES users(user_id),
                FOREIGN KEY (referred_id) REFERENCES users(user_id)
            )
        ''')
        
        conn.commit()
        conn.close()
    
    def get_user(self, user_id: int) -> Optional[Dict]:
        """Get complete user data"""
        conn = self.get_conn()
        c = conn.cursor()
        c.execute("SELECT * FROM users WHERE user_id=?", (user_id,))
        row = c.fetchone()
        conn.close()
        
        if not row:
            return None
        
        columns = [description[0] for description in c.description]
        return dict(zip(columns, row))
    
    def create_user(self, user_id: int, username: str, first_name: str, 
                    last_name: str, referred_by: Optional[int] = None) -> Dict:
        """Create new user with referral code"""
        referral_code = self._generate_ref_code()
        
        conn = self.get_conn()
        c = conn.cursor()
        c.execute('''
            INSERT INTO users (user_id, username, first_name, last_name, 
                             referral_code, referred_by, last_active)
            VALUES (?, ?, ?, ?, ?, ?, date('now'))
        ''', (user_id, username, first_name, last_name, referral_code, referred_by))
        conn.commit()
        conn.close()
        
        # Handle referral bonus
        if referred_by:
            self._process_referral(referred_by, user_id)
        
        return self.get_user(user_id)
    
    def _generate_ref_code(self) -> str:
        """Generate unique referral code"""
        return ''.join(random.choices(string.ascii_uppercase + string.digits, k=8))
    
    def _process_referral(self, referrer_id: int, referred_id: int):
        """Process referral rewards"""
        bonus = 50  # Points for referrer
        conn = self.get_conn()
        c = conn.cursor()
        
        # Add bonus to referrer
        c.execute("UPDATE users SET points = points + ? WHERE user_id=?", 
                 (bonus, referrer_id))
        
        # Record referral
        c.execute('''
            INSERT INTO referrals (referrer_id, referred_id, earned_points)
            VALUES (?, ?, ?)
        ''', (referrer_id, referred_id, bonus))
        
        conn.commit()
        conn.close()
    
    def update_user_activity(self, user_id: int):
        """Update last active timestamp"""
        conn = self.get_conn()
        c = conn.cursor()
        c.execute("UPDATE users SET last_active = date('now') WHERE user_id=?", 
                 (user_id,))
        conn.commit()
        conn.close()
    
    def add_points(self, user_id: int, points: int, source: str = "ad_watch"):
        """Add points and update stats"""
        conn = self.get_conn()
        c = conn.cursor()
        
        c.execute('''
            UPDATE users 
            SET points = points + ?, 
                total_earned = total_earned + ?,
                ads_watched = CASE WHEN ? = 'ad_watch' THEN ads_watched + 1 ELSE ads_watched END
            WHERE user_id=?
        ''', (points, points, source, user_id))
        
        # Record in history if ad watch
        if source == "ad_watch":
            c.execute('''
                INSERT INTO ad_history (user_id, points_earned)
                VALUES (?, ?)
            ''', (user_id, points))
        
        conn.commit()
        conn.close()
        self._check_level_up(user_id)
    
    def _check_level_up(self, user_id: int):
        """Check and update user level based on total earned"""
        user = self.get_user(user_id)
        if not user:
            return
        
        total = user['total_earned']
        new_level = 1
        
        for level, data in sorted(CONFIG.LEVELS.items(), reverse=True):
            if total >= data['min']:
                new_level = level
                break
        
        if new_level > user['level']:
            conn = self.get_conn()
            c = conn.cursor()
            c.execute("UPDATE users SET level = ? WHERE user_id=?", 
                     (new_level, user_id))
            conn.commit()
            conn.close()
    
    def deduct_points(self, user_id: int, points: int) -> bool:
        """Deduct points if sufficient balance"""
        user = self.get_user(user_id)
        if not user or user['points'] < points:
            return False
        
        conn = self.get_conn()
        c = conn.cursor()
        c.execute("UPDATE users SET points = points - ? WHERE user_id=?", 
                 (points, user_id))
        conn.commit()
        conn.close()
        return True
    
    def create_withdrawal(self, user_id: int, amount: int, 
                         method: str, address: str) -> int:
        """Create withdrawal request"""
        conn = self.get_conn()
        c = conn.cursor()
        c.execute('''
            INSERT INTO withdrawals (user_id, amount, method, address)
            VALUES (?, ?, ?, ?)
        ''', (user_id, amount, method, address))
        withdrawal_id = c.lastrowid
        conn.commit()
        conn.close()
        return withdrawal_id
    
    def get_leaderboard(self, limit: int = 10) -> List[Dict]:
        """Get top earners"""
        conn = self.get_conn()
        c = conn.cursor()
        c.execute('''
            SELECT user_id, first_name, total_earned, level 
            FROM users 
            WHERE is_banned = 0
            ORDER BY total_earned DESC 
            LIMIT ?
        ''', (limit,))
        rows = c.fetchall()
        conn.close()
        return [{
            'user_id': row[0],
            'name': row[1],
            'earned': row[2],
            'level': row[3]
        } for row in rows]
    
    def get_stats(self) -> Dict:
        """Get global bot statistics"""
        conn = self.get_conn()
        c = conn.cursor()
        
        c.execute("SELECT COUNT(*) FROM users")
        total_users = c.fetchone()[0]
        
        c.execute("SELECT SUM(total_earned) FROM users")
        total_earned = c.fetchone()[0] or 0
        
        c.execute("SELECT SUM(ads_watched) FROM users")
        total_ads = c.fetchone()[0] or 0
        
        c.execute("SELECT COUNT(*) FROM withdrawals WHERE status='pending'")
        pending_withdrawals = c.fetchone()[0]
        
        conn.close()
        
        return {
            'users': total_users,
            'earned': total_earned,
            'ads': total_ads,
            'pending': pending_withdrawals
        }

db = Database()

# ==================== 🎮 USER STATE MANAGEMENT ====================
class UserState:
    """Manage user states and cooldowns"""
    
    @staticmethod
    def can_watch_ad(user_id: int) -> tuple[bool, int]:
        """Check if user can watch ad (cooldown)"""
        user = db.get_user(user_id)
        if not user or not user['last_ad_watch']:
            return True, 0
        
        last_watch = datetime.fromisoformat(user['last_ad_watch'])
        elapsed = (datetime.now() - last_watch).total_seconds()
        
        if elapsed >= CONFIG.AD_COOLDOWN:
            return True, 0
        return False, int(CONFIG.AD_COOLDOWN - elapsed)
    
    @staticmethod
    def update_ad_watch(user_id: int):
        """Update last ad watch time"""
        conn = db.get_conn()
        c = conn.cursor()
        c.execute('''
            UPDATE users 
            SET last_ad_watch = ? 
            WHERE user_id=?
        ''', (datetime.now().isoformat(), user_id))
        conn.commit()
        conn.close()
    
    @staticmethod
    def get_daily_bonus_status(user_id: int) -> tuple[bool, int]:
        """Check if daily bonus is available"""
        user = db.get_user(user_id)
        if not user or not user['last_daily_bonus']:
            return True, 0
        
        last_bonus = datetime.fromisoformat(user['last_daily_bonus'])
        elapsed = (datetime.now() - last_bonus).total_seconds()
        
        if elapsed >= CONFIG.DAILY_BONUS_COOLDOWN:
            return True, 0
        return False, int(CONFIG.DAILY_BONUS_COOLDOWN - elapsed)
    
    @staticmethod
    def claim_daily_bonus(user_id: int) -> int:
        """Process daily bonus with streak"""
        user = db.get_user(user_id)
        streak = user['streak_days'] if user else 0
        
        # Check if streak continues (within 48 hours)
        if user and user['last_daily_bonus']:
            last = datetime.fromisoformat(user['last_daily_bonus'])
            if (datetime.now() - last).days <= 2:
                streak = min(streak + 1, CONFIG.MAX_STREAK_DAYS)
            else:
                streak = 1
        
        # Calculate bonus with streak multiplier
        base_bonus = CONFIG.DAILY_BONUS
        multiplier = 1 + (streak * 0.1)  # 10% per streak day
        total_bonus = int(base_bonus * multiplier)
        
        # Update user
        conn = db.get_conn()
        c = conn.cursor()
        c.execute('''
            UPDATE users 
            SET points = points + ?,
                streak_days = ?,
                last_daily_bonus = ?
            WHERE user_id=?
        ''', (total_bonus, streak, datetime.now().isoformat(), user_id))
        conn.commit()
        conn.close()
        
        return total_bonus, streak

