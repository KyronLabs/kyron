    keyboard = [
        [InlineKeyboardButton(f"{Assets.EMOJIS['ad']} WATCH ANOTHER", callback_data='confirm_watch_ad')],
        [InlineKeyboardButton(f"{Assets.EMOJIS['back']} MAIN MENU", callback_data='main_menu')]
